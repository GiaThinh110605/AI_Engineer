# print all possible combinations from the Digits: data4 = [1, 2, 3]
# results: 1, 2, 3, [1, 2], [1, 3], [2, 3], [1, 2, 3]

data4 = [1, 2, 3]
result = []
result.append(data4)
for i in range(1, 4):
    for j in range(1, 4):
        result.append([i, j])

result.append([1, 2, 3])
            
print(result)